# Database Configuration
DATABASE_URL=sqlite:///./familymvp.db

# Audio Storage
AUDIO_STORAGE_PATH=./data/audio

# WebSocket Configuration
WS_HOST=0.0.0.0
WS_PORT=8000

# Realtime ASR API (e.g., Tencent Cloud)
# Uncomment and fill in your API credentials
# REALTIME_ASR_API_KEY=your_api_key_here
# REALTIME_ASR_ENDPOINT=https://asr.tencentcloudapi.com

# Offline ASR API (e.g., Alibaba Cloud)
# Uncomment and fill in your API credentials
# OFFLINE_ASR_API_KEY=your_api_key_here
