# Dialog-OS backend — copy to .env and fill in (never commit .env)
# Required for ASR + harmful detection:
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
OPENROUTER_API_KEY=

# Optional: Tencent Cloud COS (audio storage)
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=

# Optional: embeddings for semantic harmful detection
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# App
DATABASE_URL=sqlite:///./familymvp.db
WS_HOST=0.0.0.0
WS_PORT=8000
JWT_SECRET_KEY=change-me-in-production
OPENROUTER_MODEL=google/gemma-3-27b-it
