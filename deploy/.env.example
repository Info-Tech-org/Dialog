# ========================================
# Family Emotion System - Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values

# Tencent Cloud COS (Object Storage)
COS_SECRET_ID=your_cos_secret_id_here
COS_SECRET_KEY=your_cos_secret_key_here
COS_BUCKET=your_bucket_name_here
COS_REGION=ap-guangzhou

# Tencent Cloud ASR (Speech Recognition)
TENCENT_SECRET_ID=your_tencent_secret_id_here
TENCENT_SECRET_KEY=your_tencent_secret_key_here
TENCENT_ASR_REGION=ap-guangzhou

# JWT Authentication
JWT_SECRET=change_this_to_a_random_secure_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# OpenRouter API (for LLM harmful detection)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-2-27b-it

# Database (SQLite - no need to change unless using PostgreSQL)
DATABASE_URL=sqlite:///./data/family.db

# Application Settings
APP_NAME=Family Emotion System
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Public Base URL (for generating audio URLs accessible from mobile app)
# Format: http://your-server-ip:port or https://your-domain.com
# Example: http://47.236.106.225:9000
PUBLIC_BASE_URL=http://47.236.106.225:9000

# CORS Settings (comma-separated origins)
CORS_ORIGINS=https://47.236.106.225,http://47.236.106.225,http://localhost:3000

# File Upload Settings
MAX_UPLOAD_SIZE=104857600
ALLOWED_AUDIO_FORMATS=m4a,mp3,wav,flac

# Audio Storage Path
AUDIO_UPLOAD_DIR=/app/audio/uploads
